# Copia este archivo como .env y completa los valores

# Base de datos PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=smartlogix
DB_USER=postgres
DB_PASSWORD=cambia_esta_password

# JWT — genera con: openssl rand -base64 32
JWT_SECRET=genera-con-openssl-rand-base64-32

# Contraseña del keystore SSL del API Gateway
SSL_KEYSTORE_PASSWORD=cambia_esta_password
